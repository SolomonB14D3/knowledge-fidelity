# experiments/operation_frontier/results/open_questions.jsonl
# Training data outputs (generated by adapter training, large)
experiments/operation_frontier/*_training.json
# Adapter weights (large, local only — referenced by YAML but not committed)
experiments/operation_frontier/adapters/

# Operation Destroyer — paper, figures, auto-generated outputs, planning docs
experiments/operation_destroyer/paper/
experiments/operation_destroyer/sub_experiments/figures/
