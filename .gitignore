figures/*.pdf
figures/**/*.png
figures/**/*.pdf

# Paper drafts and research notes (unpublished — submit via journal, not repo)
paper/*.md
paper/*.pdf
paper/*.tex
paper/tables/
Research_Notes.md

# Auto-generated analysis outputs (unpublished results)
docs/

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
